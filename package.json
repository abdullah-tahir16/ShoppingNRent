  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --watch src --ext js src/index.js",
    "seed": "node src/scripts/seed.js",
    "seed:reset": "node src/scripts/seed.js --reset",
    "check": "node --check src/index.js && node --check src/app.js && node --check src/scripts/seed.js",
    "test": "npm run check"
  },
