  "overrides": {
    "brace-expansion": "1.1.12",
    "braces": "3.0.3",
    "minimatch": "3.1.4"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
